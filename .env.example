# Copy this file to .env.local and fill in real values.
# .env.example is committed to git (documents what the project needs).
# .env.local is NOT committed (holds your actual secrets).

# Free key from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Reddit API credentials — needed for CI/datacenter IPs (public API returns 403 from GitHub Actions).
# Create a "script" app at https://www.reddit.com/prefs/apps → any name, redirect URI unused.
# The client id is the string under your app name; the secret is labelled "secret".
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
